# Base URL of the Global Conflict Updates API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Optional: server-only secret forwarded as X-Admin-Sync-Secret (must match backend ADMIN_SYNC_SECRET)
# ADMIN_SYNC_SECRET=

# Optional: server-side API URL override for /api/updates/sync (defaults to NEXT_PUBLIC_API_BASE_URL)
# API_BASE_URL=http://localhost:3000

# Only list updates newer than N hours (default in code: 36). Use 0 for full history.
# NEXT_PUBLIC_UPDATES_MAX_AGE_HOURS=36
