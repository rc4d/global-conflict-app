# Server
PORT=3000

# CORS for the dashboard (comma-separated). Default if unset: http://localhost:3001
# FRONTEND_ORIGIN=http://localhost:3001

# MongoDB — local Docker: npm run mongo:up
# MONGODB_URI=mongodb://127.0.0.1:27017/global-conflict-updates

# MongoDB Atlas (include DB name before ?; allow your IP in Atlas Network Access)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/global-conflict-updates?retryWrites=true&w=majority

# NewsAPI.org key — https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# How to pull articles: top-headlines (live on free tier), everything (~24h delay on free), or both (2x API calls)
# Free Developer plan: /everything is delayed ~24h; /top-headlines is not — default keeps the feed current.
# NEWS_PULL_MODE=top-headlines

# Window for /everything `from` (hours). Ignored when not using everything. Developer plan still delayed.
# NEWS_EVERYTHING_FROM_HOURS=72

# Page size per request (max 50)
# NEWS_PAGE_SIZE=30

# Optional: require this value in header X-Admin-Sync-Secret for POST /updates/sync
# ADMIN_SYNC_SECRET=generate_a_long_random_string

# Optional: cron expression (default: every 15 minutes)
# CRON_SCHEDULE=*/15 * * * *

# NewsData.io — https://newsdata.io (free ~200 req/day; use longer cron if combining with NewsAPI)
# NEWSDATA_API_KEY=your_key_here
# NEWSDATA_LANGUAGE=en
# NEWSDATA_MAX_PER_REQUEST=10
# Paid plans only: narrow results to last N hours (1–48) or minutes e.g. 90m. Omit on free tier (will error).
# NEWSDATA_TIMEFRAME=12

# Optional: drop articles older than N hours at ingest (set e.g. 12 for “latest only”; may thin the feed on free tiers)
# INGEST_MAX_ARTICLE_AGE_HOURS=0

# OpenAI — summaries on insert (optional; falls back to truncated description)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_SUMMARY_DELAY_MS=500

# Event clustering (keyword overlap + time window)
# EVENT_MATCH_WINDOW_HOURS=12
# EVENT_MIN_KEYWORD_OVERLAP=2
# EVENT_MAX_ARTICLES=20

# Event signal intel: isEscalating if more than N linked articles have createdAt in the last hour (ingestion proxy)
# EVENT_ESCALATION_THRESHOLD=5
